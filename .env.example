# Jira Service Management API Configuration
# Copy this file to .env and fill in your values

# Your Atlassian account email
JIRA_EMAIL=your-email@example.com

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
# Select scopes: read:servicedesk-request, write:servicedesk-request
JIRA_API_KEY=your-api-token-here

# Your Atlassian site URL (without https://)
JIRA_SITE_URL=yoursite.atlassian.net

# Cloud ID - get it by running: curl https://yoursite.atlassian.net/_edge/tenant_info
JIRA_CLOUD_ID=your-cloud-id-here
